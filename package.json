{
  "name": "avanquest-pdf-mcp-editor",
  "version": "0.4.146",
  "description": "Claude Desktop MCP App that renders PDFs with @avanquest/pdf-web-viewer inside the chat",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "vite build && vite build --config vite.diag.config.ts",
    "build:server": "tsc -p tsconfig.server.json && node -e \"require('fs').writeFileSync('dist/package.json', '{\\\"type\\\":\\\"module\\\"}\\n')\"",
    "build": "npm run build:ui && npm run build:server",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/server.js",
    "pack": "node scripts/bump-version.mjs && npm run build && mcpb pack . avanquest-pdf-mcp-editor.mcpb"
  },
  "dependencies": {
    "@avanquest/pdf-web-viewer": "^0.8.4",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@esbuild/win32-x64": "^0.27.7",
    "@rolldown/binding-win32-x64-msvc": "^1.1.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
